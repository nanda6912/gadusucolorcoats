{
  "version": 2,
  "name": "gadusu-color-coats",
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "functions": {
    "api/google-sheets.js": {
      "maxDuration": 10
    }
  }
}
