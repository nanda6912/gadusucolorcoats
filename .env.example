# Environment Variables Example
# Copy this file to .env and fill in your actual values

# Google Apps Script URL (Required)
# Get this from your Google Apps Script deployment
GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/AKfycbxhFVgbs3OGIXe7i8azO6tazWWdbpeCRHD1Z7lhz02n8YOpQGPsrYzK-KbW3rC2J44e/exec

# Google Sheets Proxy API Key (Optional for production)
# Generate a secure API key for authentication
GOOGLE_SHEETS_PROXY_API_KEY=your_secure_api_key_here

# Google Sheets Proxy URL (Optional - defaults to Vercel deployment)
GOOGLE_SHEETS_PROXY_URL=https://gadusuproxy.vercel.app/api/google-sheets

# Server Port (Optional - defaults to 3001)
PORT=3001
